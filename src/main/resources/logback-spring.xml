<configuration>

    <!-- File Appender -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/application.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/application.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Package-specific logging -->
    <logger name="com.realtors" level="INFO"/>
    <logger name="com.realitor.common.util.JsonAwareRowMapper" level="WARN"/>
    <logger name="org.springframework.web.servlet.resource.ResourceHttpRequestHandler" level="OFF"/>
    <logger name="org.springframework.jdbc.core.BeanPropertyRowMapper" level="WARN"/>

    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="FILE"/>
    </root>
	<statusListener class="ch.qos.logback.core.status.NopStatusListener"/>
</configuration>